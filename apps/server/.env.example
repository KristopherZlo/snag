APP_NAME=Snag
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Docker dev default. In production, set this to your public https origin.
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker service defaults. For production, point these at your managed services.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=snag
DB_USERNAME=snag
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
ARTIFACT_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniosecret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=snag
# Public URL used by the browser in Docker dev. Override for production object storage/CDN.
AWS_URL=http://localhost:9000/snag
# Internal endpoint used by Laravel containers.
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

REVERB_APP_ID=snag
REVERB_APP_KEY=snag-app-key
REVERB_APP_SECRET=snag-app-secret
# Browser-facing websocket endpoint in Docker dev. Override for production public host.
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Internal bind settings for the reverb container.
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Container bootstrap defaults. Leave migrations/cache off unless you intentionally want
# them during startup; docker-compose.dev.yml overrides a few of these for local DX.
CONTAINER_WAIT_FOR_SERVICES=1
CONTAINER_RUN_MIGRATIONS=0
CONTAINER_STORAGE_LINK=0
CONTAINER_CACHE_BOOTSTRAP=0
CONTAINER_SYNC_VENDOR=0
CONTAINER_SYNC_PUBLIC_BUILD=0

BILLING_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

INVITATION_TTL_DAYS=7
UPLOAD_SESSION_TTL_MINUTES=15
SHARE_URL_TTL_MINUTES=10
EXTENSION_CODE_TTL_MINUTES=10
PUBLIC_FINALIZE_TTL_MINUTES=5

VITE_APP_NAME="${APP_NAME}"

