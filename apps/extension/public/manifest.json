{
  "manifest_version": 3,
  "name": "Snag",
  "description": "Capture current-tab screenshots or videos and submit bug reports to Snag.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js"
  },
  "permissions": ["activeTab", "offscreen", "storage", "tabCapture", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["assets/page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "capture-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Capture the current tab"
    },
    "toggle-video-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Start or stop recording the current tab"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    }
  ]
}
