{
  "manifest_version": 3,
  "name": "Snag",
  "description": "Capture current-tab screenshots or videos and submit bug reports to Snag.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/snag-extension-button.svg",
    "32": "icons/snag-extension-button.svg",
    "48": "icons/snag-extension-button.svg",
    "128": "icons/snag-extension-button.svg"
  },
  "action": {
    "default_icon": {
      "16": "icons/snag-extension-button.svg",
      "32": "icons/snag-extension-button.svg"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js"
  },
  "permissions": ["activeTab", "offscreen", "storage", "tabCapture", "tabs", "scripting"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["assets/page-bridge.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "commands": {
    "capture-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Capture the current tab"
    },
    "toggle-video-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Start or stop recording the current tab"
    }
  }
}
